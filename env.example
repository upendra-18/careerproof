# CareerProof Backend - Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit real secrets.

# Server
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000

# Set APP_ENV=production locally only when you intentionally want production safeguards.
# Vercel production also sets VERCEL_ENV=production automatically.
APP_ENV=development

# Razorpay
# Development keys start with rzp_test_.
# Live keys start with rzp_live_ and must be configured in your production environment.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/careerproof?retryWrites=true&w=majority

# Email Provider
# Options: gmail | resend | smtp
EMAIL_PROVIDER=gmail

# Sender and support details
EMAIL_FROM="CareerProof <support@example.com>"
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+91 0000000000
WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/

# Gmail SMTP (EMAIL_PROVIDER=gmail)
# Use an App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Resend (EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_your_resend_api_key

# Generic SMTP (EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
