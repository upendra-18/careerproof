{
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60,
      "includeFiles": "{assets/**,*.html}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/careerproof.html"
    },
    {
      "source": "/careerride.html",
      "destination": "/careerproof.html"
    }
  ]
}
